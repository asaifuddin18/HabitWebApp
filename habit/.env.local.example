# Copy to .env.local and fill in.

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=            # generate: openssl rand -base64 32

# Google OAuth (console.cloud.google.com > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS access
# Local dev: use a named profile from ~/.aws/credentials
AWS_PROFILE=habit
AWS_REGION=us-east-1

# Production (Vercel) sets AWS_ROLE_ARN instead of AWS_PROFILE — the
# habit-vercel-app role ARN from the CDK stack output. Do NOT set it locally.
# AWS_ROLE_ARN=arn:aws:iam::<account>:role/habit-vercel-app

# DynamoDB table names (match the CDK stack)
HABIT_TASKS_TABLE=habit-tasks
HABIT_COMPLETIONS_TABLE=habit-completions
